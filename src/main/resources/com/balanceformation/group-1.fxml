<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.HBox?>
<VBox xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.balanceformation.Group1Controller" fx:id="root"
      spacing="15" alignment="TOP_CENTER">
    <Label text="Показники фінансової стійкості (Група 1)"
           style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

    <GridPane hgap="10" vgap="10 ">

        <Label text="Коефіцієнт миттєвої ліквідності:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
        <Label fx:id="immediateLiquidityLabel" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

        <Label text="Коефіцієнт поточної ліквідності:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
        <Label fx:id="currentLiquidityLabel" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

        <Label text="Коефіцієнт загальної ліквідності:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
        <Label fx:id="overallLiquidityLabel" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

        <Label text="Коефіцієнт фінансової незалежності:" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
        <Label fx:id="financialIndependenceLabel" GridPane.rowIndex="3" GridPane.columnIndex="1"/>

        <Label text="Коефіцієнт маневреності власних коштів:" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
        <Label fx:id="equityManeuverabilityLabel" GridPane.rowIndex="4" GridPane.columnIndex="1"/>

    </GridPane>

    <HBox spacing="15">
        <Button text="Зберегти" onAction="#handleSaveExcel" prefWidth="200"/>
        <Button text="Назад" onAction="#goBack" prefWidth="200"/>
    </HBox>

</VBox>
