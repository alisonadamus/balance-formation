<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox  xmlns="http://javafx.com/javafx" fx:id="root"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.balanceformation.Group2Controller"
            spacing="15" alignment="CENTER">

    <Label text="Аналіз прибутків та збитків (Група G2)"
           style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

    <GridPane hgap="10" vgap="10">

        <!-- INPUT -->
        <Label text="Діяльність минулих років:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
        <ComboBox fx:id="pastYearsCombo" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

        <Label text="Суми найбільшого отриманого і повернутого кредиту:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
        <TextField fx:id="largestLoanField" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

        <Label text="Сума запитуваного кредиту:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
        <TextField fx:id="requestedCreditField" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

        <!-- OUTPUT -->
        <Label text="Коефіцієнт рентабельності виробництва:" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
        <Label fx:id="productionProfitabilityLabel" GridPane.rowIndex="4" GridPane.columnIndex="1"/>

        <Label text="Коефіцієнт діяльності минулих років:" GridPane.rowIndex="5" GridPane.columnIndex="0"/>
        <Label fx:id="k7Label" GridPane.rowIndex="5" GridPane.columnIndex="1"/>

        <Label text="Коефіцієнт найбільшої суми раніше повернутого кредиту:" GridPane.rowIndex="6" GridPane.columnIndex="0"/>
        <Label fx:id="k8Label" GridPane.rowIndex="6" GridPane.columnIndex="1"/>

    </GridPane>

    <HBox spacing="15">
        <Button text="Вирахувати" onAction="#handleCalculate" prefWidth="200"/>
        <Button text="Зберегти" onAction="#handleSaveExcel" prefWidth="200"/>
        <Button text="Назад" onAction="#goBack" prefWidth="200"/>
    </HBox>


</VBox >
